{
	"nodes":[
		{"id":"center","type":"text","x":1900,"y":2100,"width":460,"height":170,"text":"# OpenCode 知识库\n\n==完整使用手册==\n9 大模块 · 31 个子章节","color":"2"},
		{"id":"g1","type":"group","x":300,"y":350,"width":460,"height":340,"label":"一、快速入门"},
		{"id":"n1t","type":"text","x":330,"y":400,"width":400,"height":60,"text":"## 快速入门\n安装启动 + 核心概念速览","color":"4"},
		{"id":"n1a","type":"file","x":330,"y":470,"width":400,"height":50,"file":"opencode.md","subpath":"#安装与启动"},
		{"id":"n1b","type":"text","x":330,"y":530,"width":400,"height":120,"text":"`opencode` 启动 TUI\n`opencode run \"prompt\"` 非交互执行\n`opencode serve` 无头服务器\n`opencode web` Web 界面"},
		{"id":"g2","type":"group","x":1050,"y":200,"width":700,"height":560,"label":"二、配置系统"},
		{"id":"n2t","type":"text","x":1080,"y":250,"width":300,"height":60,"text":"## 配置系统\n7 级优先级加载","color":"4"},
		{"id":"n2a","type":"file","x":1080,"y":320,"width":280,"height":50,"file":"opencode.md","subpath":"#配置文件位置与优先级"},
		{"id":"n2b","type":"file","x":1080,"y":380,"width":280,"height":50,"file":"opencode.md","subpath":"#配置字段速查"},
		{"id":"n2c","type":"file","x":1080,"y":440,"width":280,"height":50,"file":"opencode.md","subpath":"#Provider 配置"},
		{"id":"n2d","type":"file","x":1080,"y":500,"width":280,"height":50,"file":"opencode.md","subpath":"#变量替换"},
		{"id":"n2e","type":"text","x":1380,"y":320,"width":340,"height":50,"text":"界面配置：TUI / Server"},
		{"id":"n2f","type":"text","x":1380,"y":380,"width":340,"height":50,"text":"行为配置：Share / Compaction / Watcher"},
		{"id":"n2g","type":"text","x":1380,"y":440,"width":340,"height":110,"text":"功能配置：Permission / Agent\nFormatter / MCP / LSP / Plugin"},
		{"id":"n2h","type":"text","x":1080,"y":570,"width":640,"height":60,"text":"==单数键名==：provider / permission / agent / command / formatter","color":"1"},
		{"id":"n2i","type":"file","x":1080,"y":640,"width":280,"height":50,"file":"opencode.md","subpath":"#认证"},
		{"id":"g3","type":"group","x":2700,"y":100,"width":950,"height":830,"label":"三、Agent、Skill 与权限系统"},
		{"id":"n3t","type":"text","x":2730,"y":150,"width":370,"height":70,"text":"### Agent 系统\n4 内置 + 自定义 Agent","color":"4"},
		{"id":"n3a","type":"text","x":2730,"y":230,"width":890,"height":50,"text":"Explore → Plan → General → Build 标准工作流","color":"3"},
		{"id":"n3b","type":"text","x":2730,"y":290,"width":420,"height":100,"text":"5 种 Workflow 模式\nACI 设计 · 设计检查清单 7 项\n系统提示词二选一机制\n各模型默认 Temperature 值"},
		{"id":"n3c","type":"text","x":3170,"y":290,"width":450,"height":100,"text":"子代理硬编码限制\n(todowrite / todoread / task deny)\n透传参数：reasoningEffort 等\n常见设计陷阱 5 项"},
		{"id":"n3d","type":"text","x":2730,"y":410,"width":370,"height":70,"text":"### Skill 系统\n三层渐进式披露","color":"4"},
		{"id":"n3e","type":"text","x":2730,"y":490,"width":420,"height":80,"text":"description → SKILL.md → references/\nMCP = 厨房，Skill = 菜谱\n5 种工作流模式 · 分发共享"},
		{"id":"n3f","type":"text","x":3170,"y":410,"width":450,"height":70,"text":"### 快捷命令\n模板语法 $ARGUMENTS / $1","color":"4"},
		{"id":"n3g","type":"text","x":3170,"y":490,"width":450,"height":80,"text":"subtask 配置：强制子任务执行\n覆盖内置命令 · 嵌套目录"},
		{"id":"n3h","type":"text","x":2730,"y":600,"width":370,"height":70,"text":"### 权限系统\nallow / ask / deny","color":"4"},
		{"id":"n3i","type":"text","x":2730,"y":680,"width":890,"height":50,"text":"bash / edit / task / skill · ==最后匹配生效== · 子代理硬编码 deny · 确认键 y/a"},
		{"id":"n3j","type":"text","x":2730,"y":750,"width":890,"height":50,"text":"15+ 权限类型 · .env 保护 · doom_loop 检测 · 安全最佳实践"},
		{"id":"g4","type":"group","x":100,"y":1100,"width":530,"height":460,"label":"四、会话管理与上下文压缩"},
		{"id":"n4t","type":"text","x":130,"y":1150,"width":470,"height":70,"text":"## 会话管理\n数据存储 / 导入导出 / Fork","color":"4"},
		{"id":"n4a","type":"file","x":130,"y":1230,"width":220,"height":50,"file":"opencode.md","subpath":"#会话命令"},
		{"id":"n4b","type":"file","x":130,"y":1290,"width":220,"height":50,"file":"opencode.md","subpath":"#导入导出与 Fork"},
		{"id":"n4c","type":"file","x":370,"y":1230,"width":230,"height":50,"file":"opencode.md","subpath":"#上下文压缩"},
		{"id":"n4d","type":"text","x":130,"y":1360,"width":470,"height":140,"text":"上下文压缩：Prune + Summarize\nContext% = tokens / limit.context\nreserved = min(20K, max_output)\n自动触发：token >= limit - reserved\n压缩不删除数据库中的历史"},
		{"id":"g5","type":"group","x":3200,"y":1100,"width":660,"height":680,"label":"五、MCP、IDE 与远程连接"},
		{"id":"n5t","type":"text","x":3230,"y":1150,"width":300,"height":70,"text":"### MCP 扩展\n连接外部服务","color":"4"},
		{"id":"n5a","type":"text","x":3230,"y":1230,"width":280,"height":100,"text":"本地 MCP (stdio)\n远程 MCP (HTTP/SSE)\nOAuth 自动认证\n通配符权限管理"},
		{"id":"n5b","type":"file","x":3230,"y":1340,"width":280,"height":50,"file":"opencode.md","subpath":"#Chrome DevTools MCP 工具完整列表（28 个）"},
		{"id":"n5c","type":"text","x":3530,"y":1150,"width":300,"height":70,"text":"### IDE 集成","color":"4"},
		{"id":"n5d","type":"text","x":3530,"y":1230,"width":300,"height":120,"text":"VS Code / Cursor\nACP 协议\nNeovim (Avante/CodeCompanion)\nJetBrains / Zed keymap"},
		{"id":"n5e","type":"text","x":3230,"y":1420,"width":600,"height":70,"text":"### 远程模式与 API","color":"4"},
		{"id":"n5f","type":"text","x":3230,"y":1500,"width":600,"height":200,"text":"serve / web / attach 三种模式\n19 个 HTTP API 分类\nTUI 控制 API（12 个方法）\nSDK 三种使用方式 + 21 模块\nSSE 事件流 · Basic Auth\n网络代理 HTTPS_PROXY\n自定义证书 NODE_EXTRA_CA_CERTS\nmDNS 服务发现"},
		{"id":"g6","type":"group","x":100,"y":1900,"width":580,"height":610,"label":"六、命令行与界面"},
		{"id":"n6t","type":"text","x":130,"y":1950,"width":520,"height":70,"text":"### CLI 命令参考\nrun / serve / web / attach / uninstall","color":"4"},
		{"id":"n6a","type":"text","x":130,"y":2030,"width":520,"height":110,"text":"models / stats / debug / mcp / agent\nopencode run -f file -m model --format json\nopencode run --attach http://… 复用服务器\nopencode run --variant high/max/minimal"},
		{"id":"n6b","type":"text","x":130,"y":2160,"width":260,"height":70,"text":"### 快捷键\nLeader: Ctrl+X","color":"4"},
		{"id":"n6c","type":"text","x":130,"y":2240,"width":520,"height":110,"text":"N 新建 / L 列表 / M 模型 / A Agent\nU 撤销 / R 重做 / Y 复制 / C 压缩\n输入区 35+ 快捷键\nDesktop 桌面版 13 个快捷键\n权限确认键：y 允许 / a 始终允许"},
		{"id":"n6d","type":"text","x":400,"y":2160,"width":250,"height":70,"text":"### 主题与外观\n32 内置 + 自定义","color":"4"},
		{"id":"n6e","type":"text","x":400,"y":2240,"width":250,"height":60,"text":"`theme` 不是 `tui.theme`\nsystem 主题自动适配"},
		{"id":"g7","type":"group","x":850,"y":1900,"width":670,"height":580,"label":"七、插件与工具系统"},
		{"id":"n7t","type":"text","x":880,"y":1950,"width":300,"height":70,"text":"### 插件系统\n事件钩子 + 功能钩子","color":"4"},
		{"id":"n7a","type":"text","x":880,"y":2030,"width":300,"height":130,"text":"tool.execute.before/after\nchat.params LLM 参数修改\npermission.ask 自动决策\nauth 认证插件\n上下文 6 参数\n加载顺序 4 级"},
		{"id":"n7b","type":"text","x":880,"y":2170,"width":610,"height":70,"text":"自定义工具: tool() + Zod schema · Python/HTTP 调用","color":"5"},
		{"id":"n7c","type":"text","x":1200,"y":1950,"width":290,"height":70,"text":"### 内置工具\n17 个工具详解","color":"4"},
		{"id":"n7d","type":"text","x":1200,"y":2030,"width":290,"height":130,"text":"bash / edit（9 层匹配）\nread / write / grep / glob\nwebfetch / websearch\nbatch（实验性并行）\n每个工具 AI 调用参数表"},
		{"id":"n7e","type":"text","x":880,"y":2260,"width":610,"height":160,"text":"### 高级功能\nFormatter 21 个（prettier/biome/gofmt/ruff/rustfmt…）\nLSP 35+ 语言服务器（9 种操作）\n思考深度：variants 配置（Ctrl+T 切换）\n调试：debug config/skill/agent/lsp\nGit Worktree 多分支并行\n规则与指令：AGENTS.md / /init / instructions"},
		{"id":"g8","type":"group","x":2600,"y":2700,"width":780,"height":640,"label":"八、实战与企业"},
		{"id":"n8t","type":"text","x":2630,"y":2750,"width":350,"height":70,"text":"### CI/CD 集成\nGitHub Actions / GitLab CI","color":"4"},
		{"id":"n8a","type":"text","x":2630,"y":2830,"width":350,"height":130,"text":"触发词 /oc 或 /opencode\n6 种事件类型\n7 步处理流程\nFork PR 处理方式\nCo-author 归属\nopencode github install"},
		{"id":"n8b","type":"text","x":3010,"y":2750,"width":340,"height":70,"text":"### 企业功能\n三种认证接入方式","color":"4"},
		{"id":"n8c","type":"text","x":3010,"y":2830,"width":340,"height":130,"text":"A. 环境变量（最省事）\nB. well-known（统一登录+配置下发）\nC. 认证插件（最灵活）\nenterprise.url\n私有 NPM 注册表\ntoken 进程级注入"},
		{"id":"n8d","type":"text","x":2630,"y":2990,"width":350,"height":70,"text":"### 场景应用\n开发工作流 / 重构 / 文档","color":"4"},
		{"id":"n8e","type":"text","x":2630,"y":3070,"width":720,"height":210,"text":"Prompt 工程 7 条核心原则\n占位符规范语法（5 种类型）\nAgent/Skill description 规范模板\n13 个 Prompt 模板（写作 7 + 开发 6）\n专属 Agent 创建（Code Reviewer / Security Auditor / Test Writer）\n组合命令工作流\n!命令执行 shell · /workspaces 切换"},
		{"id":"g9","type":"group","x":800,"y":2750,"width":720,"height":560,"label":"九、参考资料与附录"},
		{"id":"n9t","type":"text","x":830,"y":2800,"width":660,"height":70,"text":"### 参考资料\n75+ 提供商 · 故障排除 · FAQ · 生态系统","color":"4"},
		{"id":"n9a","type":"text","x":830,"y":2880,"width":330,"height":140,"text":"国产: DeepSeek/Moonshot/MiniMax/Z.AI\n国际: Anthropic/OpenAI/Gemini/xAI/Mistral\n云平台: Bedrock/Azure/Cloudflare\n聚合: OpenRouter/Groq/Cerebras\n本地: Ollama/LM Studio/llama.cpp"},
		{"id":"n9b","type":"text","x":830,"y":3030,"width":330,"height":140,"text":"错误代码速查表（HTTP + 内部）\nAPI 自动重试（2x 退避，最大 30s）\n输出截断（2000 行 / 50 KB）\n上下文溢出 15 个提供商错误信息\n诊断三连: version / auth / DEBUG\n0.x → 1.0 迁移（键绑定重命名）"},
		{"id":"n9c","type":"text","x":1180,"y":2880,"width":310,"height":70,"text":"### OpenCode Zen\n24 个精选模型","color":"4"},
		{"id":"n9d","type":"text","x":1180,"y":2960,"width":310,"height":100,"text":"GPT 5.2 · Claude Sonnet/Opus 4.5\nGemini 3 · GLM 4.7 · Kimi K2\n4 种 API 端点格式\nopencode.ai/auth 获取 Key"},
		{"id":"n9e","type":"text","x":1180,"y":3070,"width":310,"height":150,"text":"### 附录速查\n环境变量 10+ · 配置完整示例\n实验性功能完整列表\n社区插件 23 个\n社区项目 8 个\n/export 导出格式说明\n限制 AI 只读方法"}
	],
